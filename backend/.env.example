# Copy this file to .env and fill in real values before running the server.
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"

SECRET_KEY=replace-with-64-char-random-hex
DATABASE_URL=sqlite:///./atai_travel.db
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FRONTEND_URL=http://localhost:5173
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
# For Vercel + Railway production over HTTPS:
# FRONTEND_URL=https://your-vercel-app.vercel.app
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
#
# "development" → /docs visible, create_all on startup
# "production"  → /docs hidden, alembic migrations required
ENVIRONMENT=development
